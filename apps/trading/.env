# CASH Trading App Environment — Aptos only.
# EVM RPC keys (Infura/QuickNode/Alchemy), Solana (Jupiter), and MoonPay are
# intentionally blanked: this app routes swaps through Panora on Aptos, so
# none of those endpoints are ever called. Leaving the variable names in place
# so any inherited Uniswap code that reads them gets empty strings.
ESLINT_NO_DEV_ERRORS=true
REACT_APP_AMPLITUDE_PROXY_URL=""
REACT_APP_AWS_API_ENDPOINT=""
REACT_APP_INFURA_KEY=""
REACT_APP_QUICKNODE_ENDPOINT_NAME=""
REACT_APP_QUICKNODE_ENDPOINT_TOKEN=""
REACT_APP_MOONPAY_API=""
REACT_APP_MOONPAY_LINK=""
REACT_APP_STATSIG_API_KEY=""
REACT_APP_STATSIG_PROXY_URL=""
REACT_APP_TEMP_API_URL=""
REACT_APP_UNISWAP_GATEWAY_DNS=""
REACT_APP_WALLET_CONNECT_PROJECT_ID=""
REACT_APP_TRADING_API_KEY=""
REACT_APP_IS_UNISWAP_INTERFACE=true

# CASH Orderbook API
VITE_API_URL=http://localhost:3100
VITE_WS_URL=ws://localhost:3101
VITE_APTOS_NETWORK=testnet
VITE_CONTRACT_ADDRESS=0xe66fef668077ab8dc5ea65539b6250d8ca3fc024ea4f16555fca9eaeb73b41d1
