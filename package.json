{
  "name": "cash-orderbook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "dev": "concurrently -n api,ws,web -c green,blue,magenta \"pnpm --filter @cash/api dev\" \"pnpm --filter @cash/api dev:ws\" \"pnpm --filter @cash/web dev\"",
    "dev:all": "turbo run dev --parallel",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@8.7.4",
  "engines": {
    "node": ">=20.0.0"
  }
}
