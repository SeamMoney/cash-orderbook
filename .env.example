# Aptos Configuration
APTOS_PRIVATE_KEY=           # Deployer private key (never commit!)
APTOS_NETWORK=mainnet        # mainnet or testnet
APTOS_API_KEY=               # Optional, for rate-limited RPC

# Contract
CONTRACT_ADDRESS=            # Deployed contract address

# Services
PORT=3100                    # REST API server port
WS_PORT=3101                 # WebSocket server port
NEXT_PUBLIC_API_URL=http://localhost:3100
NEXT_PUBLIC_WS_URL=ws://localhost:3101

# Token Addresses (mainnet) — see shared/src/index.ts for defaults
CASH_TOKEN_ADDRESS=           # CASH token metadata address
USDC_TOKEN_ADDRESS=           # USDC token metadata address
